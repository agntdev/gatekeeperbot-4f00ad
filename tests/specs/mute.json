[
  {
    "name": "/mute with missing args shows usage",
    "steps": [
      {
        "send": { "text": "/mute" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /mute @username <duration> (e.g. 1h, 30m)"
            }
          }
        ]
      }
    ]
  }
]
